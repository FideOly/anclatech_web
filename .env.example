# ============================================================
# VARIABLES DE ENTORNO - AnclaTech Solutions
# ============================================================
# 
# NO subas este archivo con valores reales al repositorio.
# Usa SOLO para referencia local y copia los valores a Netlify.
#
# En Netlify: Dashboard > Site Settings > Build & Deploy > Environment
#
# ============================================================

# reCAPTCHA v3 - Clave Secreta
# Obtén en: https://www.google.com/recaptcha/admin
# Usa la clave SECRETA (private key), no la pública
RECAPTCHA_SECRET=tu_recaptcha_secret_key_aqui

# Formspree - Endpoint completo del formulario
# Obtén el Form ID en: https://formspree.io/
# Formato: https://formspree.io/f/FORM_ID
FORMSPREE_ENDPOINT=https://formspree.io/f/tu_form_id_aqui

# ============================================================
# INSTRUCCIONES RÁPIDAS:
# ============================================================
#
# 1. Ve a https://www.google.com/recaptcha/admin
# 2. Crea un nuevo sitio (reCAPTCHA v3)
# 3. Copia la clave SECRETA aquí
# 4. Ve a https://formspree.io/
# 5. Crea un nuevo formulario
# 6. Copia el Form ID y construye: https://formspree.io/f/xxxxx
# 7. Copia AMBAS variables a Netlify (sin este archivo)
#
# ============================================================
